---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="Hardware Notes" description="Notes and checklists for hardware troubleshooting and upgrades.">
	<div class="card-base p-8">
		<p class="text-lg">Practical notes for hardware assembly, upgrades, and boot diagnostics.</p>
		<ul class="mt-6 list-disc pl-6 space-y-2">
			<li>Build logs and compatibility checklists</li>
			<li>Boot and display issue troubleshooting</li>
			<li>PC cooling, power, and component recommendations</li>
		</ul>
	</div>
</MainGridLayout>
