---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="Services" description="No formal service offerings yet; these are my open resources and notes.">
	<div class="card-base p-8">
		<p class="text-lg">Current services and support I can offer:</p>
		<ul class="mt-6 list-disc pl-6 space-y-2">
			<li>PC and server build guidance</li>
			<li>Troubleshooting consultations for boot and hardware issues</li>
			<li>Guidance on ComfyUI and personal AI workflow setup</li>
		</ul>
		<p class="text-sm text-(--content-meta) mt-6">Please contact via email for collaboration details.</p>
	</div>
</MainGridLayout>
